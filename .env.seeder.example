# ────────────────────────────────────────────────────────────────
# Beacon Seeder Environment — EXAMPLE FILE
# Copy to .env.seeder and fill in your actual values.
# Never commit .env.seeder to version control.
# ────────────────────────────────────────────────────────────────

# Firebase Admin (Realtime Database)
FIREBASE_DATABASE_URL="https://YOUR_PROJECT_ID.firebaseio.com"
FIREBASE_SERVICE_ACCOUNT_PATH="./service-account.json"

# Super Admin Bootstrap (used by npm run seed:bootstrap:admin)
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="CHANGE_ME_USE_STRONG_PASSWORD"
SEED_ADMIN_DISPLAY_NAME="Platform Admin"

# Demo Student (optional — used only by npm run seed:demo:users)
# Do NOT run in production.
SEED_STUDENT_EMAIL="student@yourdomain.com"
SEED_STUDENT_PASSWORD="CHANGE_ME_USE_STRONG_PASSWORD"
SEED_STUDENT_DISPLAY_NAME="Demo Student"

# Supabase Storage (server-side only — never expose in frontend)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_COVER_BUCKET="beacon-resource-covers"
SUPABASE_GENERATED_FILES_BUCKET="beacon-generated-files"
SUPABASE_TEMPLATES_BUCKET="beacon-templates"

# Google Gemini API (server-side only)
GEMINI_API_KEY="your-gemini-api-key"
