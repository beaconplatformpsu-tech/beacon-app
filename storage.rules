rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Public read for logged-in users, write restricted to owner and validated
    match /users/{userId}/avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Resources: Public read for logged-in users, writable by authenticated admins
    // Secured with custom claim verification to ensure only admins can upload files
    match /resources/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.admin == true
                   && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
