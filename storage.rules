rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Public read for logged-in users, write restricted to owner and validated
    match /users/{userId}/avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Resources: Public read for logged-in users, writable by authenticated users
    // TODO: Admin writes are currently protected by application logic and Realtime DB rules, 
    // but in Firebase Storage without custom claims, we restrict to auth != null.
    // For full security, move resource uploads to a Server Action / Cloud Function that validates admin claims.
    match /resources/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
