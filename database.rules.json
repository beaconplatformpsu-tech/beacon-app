{
  "rules": {
    ".read": false,
    ".write": false,

    "public_content": {
      ".read": true,
      ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      "resources": {
        ".indexOn": ["createdAt", "updatedAt", "resourceType", "difficultyLevel", "provider", "sourceType"]
      },
      "skills": {
        ".indexOn": ["categoryId", "sortOrder", "createdAt", "isActive"]
      },
      "career_paths": {
        ".indexOn": ["categoryId", "createdAt", "isActive"]
      },
      "skill_categories": {
        ".indexOn": ["sortOrder", "createdAt"]
      },
      "career_categories": {
        ".indexOn": ["sortOrder", "createdAt"]
      },
      "academic_categories": {
        ".indexOn": ["sortOrder", "createdAt"]
      },
      "announcements": {
        ".indexOn": ["createdAt", "isActive"]
      }
    },

    "indexes": {
      ".read": true,
      ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'"
    },

    "relations": {
      ".read": true,
      ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      "career_path_skills": {
        ".indexOn": ["importanceLevel", "minimumProficiencyLevel", "learningOrder"]
      }
    },

    "users": {
      ".read": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["createdAt"],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "user_private": {
      ".read": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "tasks": {
          ".indexOn": ["dueDate", "status", "priority", "createdAt"]
        },
        "notes": {
          ".indexOn": ["createdAt", "updatedAt", "isPinned"]
        },
        "user_skills": {
          ".indexOn": ["skillId", "proficiency", "progress"]
        },
        "cv_profile": {
          ".indexOn": ["updatedAt"]
        },
        "cv_analysis": {
          ".indexOn": ["createdAt"]
        },
        "recommendations": {
          ".indexOn": ["createdAt", "isDismissed"]
        }
      }
    },

    "user_admin_meta": {
      ".read": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["role", "accountStatus", "createdAt"]
    },

    "support_messages": {
      ".read": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["createdAt", "status", "type"],
      "$messageId": {
        ".write": "!data.exists() || (auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "platform_settings": {
      "public": {
        ".read": true,
        ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'"
      },
      "private": {
        ".read": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
        ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "stats": {
      ".read": true,
      ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'"
    },

    "system": {
      ".read": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('user_admin_meta').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
